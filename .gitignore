# Dependencies
node_modules/
.pnp
.pnp.js

# Next.js
.next/
out/

# Environment variables — NEVER commit these
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Build outputs
dist/
build/

# Rust / Tauri build artifacts
src-tauri/target/
src-tauri/gen/
# Machine-specific Cargo config (MSVC lib paths — not portable across machines)
src-tauri/.cargo/

# OS
.DS_Store
Thumbs.db

# SQLite DBs — the real DB lives in %APPDATA%\rushcut, never in the repo.
# Guards against stray DB files written with a corrupted path-as-filename.
*.db
*.db-shm
*.db-wal
*.sqlite

# Editor
.vscode/
.idea/
*.swp

# AWS / Serverless
.serverless/
cdk.out/

# Test failure screenshots
e2e/screenshots/

# Logs
*.log
npm-debug.log*

# Test uploads / local video files — never commit raw footage
src/test-clips/
*.mp4
*.mov
*.MP4
*.MOV

# Spike working files
spike/tmp/
spike/output*

# Claude Code worktrees (temporary git worktrees created by the Agent tool)
.claude/worktrees/

# Next.js build info
tsconfig.tsbuildinfo
__pycache__/
*.pyc
.venv/
venv/

.vercel
