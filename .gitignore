# Dependencies
node_modules/
.pnp
.pnp.js

# Next.js
.next/
out/

# Environment variables — NEVER commit these
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Build outputs
dist/
build/

# Rust / Tauri build artifacts
src-tauri/target/
src-tauri/gen/
# Machine-specific Cargo config (MSVC lib paths — not portable across machines)
src-tauri/.cargo/

# OS
.DS_Store
Thumbs.db

# SQLite DBs — the real DB lives in %APPDATA%\rushcut, never in the repo.
# Guards against stray DB files written with a corrupted path-as-filename.
*.db
*.db-shm
*.db-wal
*.sqlite

# Editor
.vscode/
.idea/
*.swp

# AWS / Serverless
.serverless/
cdk.out/

# Test failure screenshots
e2e/screenshots/

# Logs
*.log
npm-debug.log*

# Test uploads / local video files — never commit raw footage
src/test-clips/
*.mp4
*.mov
*.MP4
*.MOV

# Spike working files
spike/tmp/
spike/output*

# Claude Code dev tooling — not part of the product; settings.local.json must never be public.
# Exception (2026-07-24, documented in CLAUDE.md's ".claude/ is gitignored" rule): 6 exact files
# implementing the search-verification governance hooks are version-controlled — reviewable and
# recoverable, not local-only. Everything else under .claude/ (skills, other agents,
# settings.json/settings.local.json, local config) stays fully ignored, exactly as before.
# Git will not apply a nested `!` negation under an excluded parent directory unless traversal is
# explicitly reopened first — hence the `dir/` then `dir/*` pairs below, not a single pattern.
.claude/*
!.claude/hooks/
.claude/hooks/*
!.claude/hooks/enforce-pp-plan-gates.js
!.claude/hooks/enforce-pp-wrapup-signoff.js
!.claude/hooks/lib/
.claude/hooks/lib/*
!.claude/hooks/lib/transcript.js
!.claude/hooks/lib/transcript.test.js
!.claude/agents/
.claude/agents/*
!.claude/agents/rushcut-real-pp-auditor.md
!.claude/agents/rushcut-pp-consultant.md

# Next.js build info
tsconfig.tsbuildinfo
__pycache__/
*.pyc
.venv/
venv/

.vercel
