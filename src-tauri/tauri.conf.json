{
  "identifier": "com.rushcut.app",
  "build": {
    "beforeDevCommand": "pnpm dev:vite",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build:vite",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      { "title": "RushCut", "width": 1280, "height": 800, "visible": false, "dragDropEnabled": false }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA\\rushcut\\**", "C:\\**", "D:\\**", "E:\\**"]
      }
    }
  },
  "plugins": {
    "dialog": null
  }
}
